        "Projects": [
            {
                "Title": "Dynamic Component Render Engine",
                "OnelineDescription": "A configuration-driven React rendering system that dynamically constructs complete UI pages from backend metadata.",
                "indexPageButtonLabel": "Learn more",
                "backToHomeButtonLabel": "Back to Portfolio",
                "BriefDescription": "",
                "madeWith": [
                    "React js",
                    "Javascript"
                ],
                "sections": [
                    {
                        "title": "Overview",
                        "iconUrl": "icons/overview.svg",
                        "type": "plainList",
                        "content": [
                            {
                                "primaryText": "",
                                "secondaryText": "A dynamic UI rendering framework built in React that consumes structured configuration from backend APIs and automatically constructs page layouts. The system eliminates repetitive manual wiring of sections and fields by interpreting hierarchical metadata and mapping it to reusable component registries."
                            },
                            {
                                "primaryText": "Problem:",
                                "secondaryText": "UI pages were driven by backend configuration, but developers still had to manually create and connect components for every new section or field."
                            },
                            {
                                "primaryText": "Challenge:",
                                "secondaryText": "As pages became more complex, repeated manual mapping increased code duplication and reduced maintainability."
                            },
                            {
                                "primaryText": "Solution:",
                                "secondaryText": "Designed a recursive render engine that interprets configuration trees and automatically generates the component hierarchy."
                            }
                        ]
                    },
                    {
                        "title": "Architecture",
                        "iconUrl": "icons/architecture.svg",
                        "type": "plainList",
                        "content": [
                            {
                                "primaryText": "Recursive Render Core:",
                                "secondaryText": "A React component that renders nested sections and fields dynamically based on hierarchical metadata."
                            },
                            {
                                "primaryText": "Section Registry:",
                                "secondaryText": "Maps configuration-defined section types to reusable layout components (tabs, collapsible blocks, grid layouts, etc.)."
                            },
                            {
                                "primaryText": "Field Registry:",
                                "secondaryText": "Maps field definitions to reusable UI components (text, image, input, dynamic display components)."
                            },
                            {
                                "primaryText": "Externalized Control Layer:",
                                "secondaryText": "Event handling and business logic are managed at the parent component level, keeping rendering and logic clearly separated."
                            }
                        ]
                    },
                    {
                        "title": "Key Capabilities",
                        "iconUrl": "icons/capability.svg",
                        "type": "plainList",
                        "content": [
                            {
                                "primaryText": "Configuration-Driven UI:",
                                "secondaryText": "Entire pages can be generated from backend metadata without modifying structural UI code."
                            },
                            {
                                "primaryText": "Plug-and-Replace Components:",
                                "secondaryText": "Sections and fields can be swapped by updating registry mappings rather than rewriting page structure."
                            },
                            {
                                "primaryText": "Scalable Design:",
                                "secondaryText": "New component types can be introduced without altering the core rendering engine."
                            },
                            {
                                "primaryText": "Improved Development Velocity:",
                                "secondaryText": "Significantly reduced repetitive UI scaffolding and streamlined complex page development."
                            }
                        ]
                    },
                    {
                        "title": "Core Elements",
                        "iconUrl": "icons/techStack.svg",
                        "type": "largeIconTextBoxList",
                        "content": [
                            "HTML",
                            "CSS",
                            "Javascript",
                            "React js",
                            "REST API"
                        ]
                    }
                ]
            },
            {
                "Title": "Configurable Query Builder Module",
                "OnelineDescription": "A dynamic, rule-based filtering system supporting nested groups, logical operators, and metadata-driven configuration.",
                "indexPageButtonLabel": "Learn more",
                "backToHomeButtonLabel": "Back to Portfolio",
                "BriefDescription": "",
                "madeWith": [
                    "React js",
                    "Javascript"
                ],
                "sections": [
                    {
                        "title": "Overview",
                        "iconUrl": "icons/overview.svg",
                        "type": "plainList",
                        "content": [
                            {
                                "primaryText": "",
                                "secondaryText": "A flexible, metadata-driven filtering module designed to construct complex query conditions dynamically. Built to extend beyond a simple four-field filter requirement, the system supports nested rule groups, logical operators (AND/OR), configurable field types, and dynamic operator mapping — enabling scalable and reusable filtering across data grids."
                            },
                            {
                                "primaryText": "Initial Requirement:",
                                "secondaryText": "Implement a basic filter on a data grid using four parameters."
                            },
                            {
                                "primaryText": "Extended Vision:",
                                "secondaryText": "Designed a reusable query builder capable of handling multiple rule groups, logical operators, and scalable metadata-driven configuration."
                            },
                            {
                                "primaryText": "Core Structure:",
                                "secondaryText": "Filters are represented as a hierarchical object consisting of rule groups (AND/OR logic) and individual rule criteria."
                            }
                        ]
                    },
                    {
                        "title": "Architecture",
                        "iconUrl": "icons/architecture.svg",
                        "type": "plainList",
                        "content": [
                            {
                                "primaryText": "Root Group Model:",
                                "secondaryText": "A non-removable base group acts as the root of the filter tree, managing nested rules and sub-groups."
                            },
                            {
                                "primaryText": "Rule Object Structure:",
                                "secondaryText": "Each rule consists of a field selector, operator selector, and dynamically determined value input."
                            },
                            {
                                "primaryText": "Operator Registry:",
                                "secondaryText": "Operators are mapped to field types, ensuring only valid comparisons are available for each field."
                            },
                            {
                                "primaryText": "Field Registry:",
                                "secondaryText": "Dynamic value input components are rendered based on field type and selected operator."
                            },
                            {
                                "primaryText": "Metadata-Driven Configuration:",
                                "secondaryText": "Field definitions and operator mappings are provided externally via structured metadata."
                            }
                        ]
                    },
                    {
                        "title": "Key Capabilities",
                        "iconUrl": "icons/capability.svg",
                        "type": "plainList",
                        "content": [
                            {
                                "primaryText": "Nested Logical Groups:",
                                "secondaryText": "Supports multiple rule groups with AND/OR logic combinations."
                            },
                            {
                                "primaryText": "Dynamic UI Rendering:",
                                "secondaryText": "Filter interface adapts automatically based on metadata configuration."
                            },
                            {
                                "primaryText": "Controlled Scalability:",
                                "secondaryText": "Ability to limit the number of groups and rules vertically or horizontally."
                            },
                            {
                                "primaryText": "State-Driven Query Object:",
                                "secondaryText": "Maintains a structured filter object that can be serialized and passed to parent components."
                            },
                            {
                                "primaryText": "Collapsible Summary View:",
                                "secondaryText": "Provides a non-editable snapshot of active filters with option to reopen and modify."
                            }
                        ]
                    },
                    {
                        "title": "Core Elements",
                        "iconUrl": "icons/techStack.svg",
                        "type": "largeIconTextBoxList",
                        "content": [
                            "React js",
                            "Javascript",
                            "Dynamic Form Rendering",
                            "Registry Pattern",
                            "State Driven UI"
                        ]
                    }
                ]
            },
            {
